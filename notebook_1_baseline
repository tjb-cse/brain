100:.2f}%', ha='center', va='bottom', fontsize=9, fontweight='bold'\n    )\nax.set_xticks(x_pos)\nax.set_xticklabels([f'Fold {r[\"fold\"]}' for r in fold_results])\nax.set_ylim(max(50, (mean_acc - 5 * std_acc) * 100), 100)\nax.set_ylabel('Validation Accuracy (%)')\nax.set_title('5-Fold Cross-Validation Accuracy per Fold', fontsize=12, fontweight='bold')\nax.legend(loc='lower right')\nax.grid(axis='y', alpha=0.3)\nplt.tight_layout()\nplt.savefig(f'{LOG_DIR}/kfold_accuracy_bars.png', dpi=150, bbox_inches='tight')\nplt.show()\n\n# ── Aggregate confusion matrix across all 5 folds ─────────────────────────\nprint(\"\\nAggregate confusion matrix (all 5 folds combined):\")\nplot_confusion_matrix(\n    np.array(all_val_true), np.array(all_val_pred),\n    title=f'Aggregate Confusion Matrix — All {K_FOLDS} Folds',\n    save_path=f'{LOG_DIR}/kfold_aggregate_confusion_matrix.png'\n)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-06T08:29:47.215968Z","iopub.execute_input":"2026-06-06T08:29:47.216274Z","iopub.status.idle":"2026-06-06T08:29:48.316611Z","shell.execute_reply.started":"2026-06-06T08:29:47.216251Z","shell.execute_reply":"2026-06-06T08:29:48.315968Z"}},"outputs":[{"name":"stdout","text":"\n============================================================\n  APPROACH 2 — 5-Fold CV Summary Statistics\n============================================================\n  Fold         Val Accuracy       Val F1\n  ----------------------------------------\n  Fold 1            0.9848       0.9848\n  Fold 2            0.9893       0.9893\n  Fold 3            0.9768       0.9767\n  Fold 4            0.9902       0.9902\n  Fold 5            0.9821       0.9822\n  ----------------------------------------\n  Mean              0.9846       0.9846\n  Std               0.0049       0.0049\n\n  Mean Accuracy : 0.9846  (98.46%)\n  Std Deviation : 0.0049\n  95% CI        : [98.03%,  98.89%]\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figur