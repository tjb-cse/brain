or: #0087ff; text-decoration-color: #0087ff\">GlobalAveragePooling2D</span>)    │ (<span style=\"color: #00d7ff; text-decoration-color: #00d7ff\">None</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">512</span>)            │             <span style=\"color: #00af00; text-decoration-color: #00af00\">0</span> │\n├─────────────────────────────────┼────────────────────────┼───────────────┤\n│ dense_head (<span style=\"color: #0087ff; text-decoration-color: #0087ff\">Dense</span>)              │ (<span style=\"color: #00d7ff; text-decoration-color: #00d7ff\">None</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">128</span>)            │        <span style=\"color: #00af00; text-decoration-color: #00af00\">65,664</span> │\n├─────────────────────────────────┼────────────────────────┼───────────────┤\n│ dropout (<span style=\"color: #0087ff; text-decoration-color: #0087ff\">Dropout</span>)               │ (<span style=\"color: #00d7ff; text-decoration-color: #00d7ff\">None</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">128</span>)            │             <span style=\"color: #00af00; text-decoration-color: #00af00\">0</span> │\n├─────────────────────────────────┼────────────────────────┼───────────────┤\n│ predictions (<span style=\"color: #0087ff; text-decoration-color: #0087ff\">Dense</span>)             │ (<span style=\"color: #00d7ff; text-decoration-color: #00d7ff\">None</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">4</span>)              │           <span style=\"color: #00af00; text-decoration-color: #00af00\">516</span> │\n└─────────────────────────────────┴────────────────────────┴───────────────┘\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"\u001b[1m Total params: \u001b[0m\u001b[38;5;34m14,780,868\u001b[0m (56.38 MB)\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Total params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">14,780,868</span> (56.38 MB)\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"\u001b[1m Trainable params: \u001b[0m\u001b[38;5;34m66,180\u001b[0m (258.52 KB)\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Trainable params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">66,180</span> (258.52 KB)\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"\u001b[1m Non-trainable params: \u001b[0m\u001b[38;5;34m14,714,688\u001b[0m (56.13 MB)\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Non-trainable params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">14,714,688</span> (56.13 MB)\n</pre>\n"},"metadata":{}},{"name":"stdout","text":"\nTotal parameters     : 14,780,868\nTrainable parameters : 66,180  (custom head only — backbone frozen)\n\nModel architecture verified.\n","output_type":"stream"}],"execution_count":11},{"id":"7fa9053e","cell_type":"markdown","source":"## 5. Callbacks\n\nThree callbacks are used in every training phase:\n\n| Callback | Purpose |\n|---|---|\n| `ModelCheckpoint` | Saves the weights that achieved the highest val_accuracy, regardless of when training stops |\n| `EarlyStopping` | Halts training when val_accuracy does not improve for `PATIENCE` consecutive epochs; `restore_best_weights=True` loads the saved checkpoint automatically |\n| `ReduceLROnPlateau` | Halves the learning rate when val_loss plateaus for 3 epochs, helping escape shallow local minima |\n| `CSVLogger` | Writes per-epoch metrics to disk for post-hoc analysis and thesis figures |","metadata":{}},{"id":"dc0cd319","cell_type":"code","source":"def get_callbacks(fold_id, phase='initial'):\n    \"\"\"\n    Return a list of Keras callbacks for one (fold, phase) combination.\n\n    Parameters\n    ----------\n    fold_id : str or int  — used for unique file naming ('A1', 1, 2, ...)\n    phase   : str         — 'initial' (frozen) or 'finetune' (unfrozen)\n\n    Returns\n    -------\n    callbacks : list of keras.callbacks.Callback\n    ckpt_path : str — path where best model weights are saved\n    \"\"\"\n    ckpt_path = os.path.join(SAVE_DIR, f'vgg16_fold{fold_id}_{phase}_best.keras')\n    log_path  = os.path.join(LOG_DIR,  f'fold{fold_id}_{phase}_log.csv')\n\n    callbacks = [\n        ModelCheckpoint(\n            filepath=ckpt_path,\n            monitor='val_accuracy',\n            save_best_only=True,\n            save_weights_only=False,   # save full model for portability\n            mode='max',\n            verbose=1\n        ),\n        EarlyStopping(\n            monitor='val_accuracy',\n            patience=PATIENCE,\n            restore_best_weights=True,\n            verbose=1\n        ),\n        ReduceLROnPlateau(\n            monitor='val_loss',\n            factor=0.5,\n            patience=3,\n            min_lr=1e-7,\n            verbose=1\n        ),\n        CSVLogger(log_path, append=False)\n    ]\n    return callbacks, ckpt_path\n\n\nprint(\"Callbacks factory defined.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-06T07:02:05.589105Z","iopub.execute_input":"2026-06-06T07:02:05.589521Z","iopub.status.idle":"2026-06-06T07:02:05.596715Z","shell.execute_reply.started":"2026-06-06T07:02:05.589492Z","shell.execute_reply":"2026-06-06T07:02:05.595872Z"}},"outputs":[{"name":"stdout","text":"Callbacks factory defined.\n","output_type":"stream"}],"execution_count":12},{"id":"dc6f586c","cell_type":"markdown","source":"## 6. Evaluation Utilities\n\nAll evaluation functions are defined once and reused across all three\napproaches.  Using a single shared function eliminates any risk of\ninconsistency in metric calculation between approaches.\n\nMetrics reported per the thesis protocol:\n- **Accuracy** — overall percentage of correctly classified samples\n- **Per-class Precision, Recall, F1** — macro-averaged for balanced classes\n- **Confusion Matrix** — both raw count and row-normalised (recall per class)","metadata":{}},{"id":"42aa7a92","cell_type":"code","source":"def evaluate_model(model, paths, labels, dataset_name='Dataset'):\n    \"\"\"\n    Predict on every image in (paths, labels) and report full metrics.\n\n    Parameters\n    ----------\n    model        : trained tf.keras.Model\n    paths        : np.ndarray of str\n    labels       : np.ndarray of int\n    dataset_name : str — displayed in console header\n\n    Returns\n    -------\n    dict with keys: accuracy, y_true, y_pred, y_pred_probs\n    \"\"\"\n    ds           = make_dataset(paths, labels, augment=False, shuffle_data=False)\n    y_pred_probs = model.predict(ds, verbose=0)\n    y_pred       = np.argmax(y_pred_probs, axis=1)\n    y_true       = labels.astype(np.int32)\n\n    acc  = accuracy_score(y_true, y_pred)\n    prec = precision_score(y_true, y_pred, average='macro', zero_division=0)\n    rec  = recall_score(y_true, y_pred, average='macro', zero_division=0)\n    f1   = f1_score(y_true, y_pred, average='macro', zero_division=0)\n\n    print(f\"\\n{'='*60}\")\n    print(f\"  {dataset_name}\")\n    print(f\"{'='*60}\")\n    print(f\"  Accuracy  : {acc:.4f}  ({acc*100:.2f}%)\")\n    print(f\"  Precision : {prec:.4f}  (macro-average)\")\n    print(f\"  Recall    : {rec:.4f}  (macro-average)\")\n    print(f\"  F1-Score  : {f1:.4f}  (macro-average)\")\n    print(f\"\\n  Per-Class Classification Report:\")\n    print(classification_report(y_true, y_pred, target_names=CLASSES, digits=4))\n\n    return {\n        'accuracy'      : acc,\n        'precision'     : prec,\n        'recall'        : rec,\n        'f1'            : f1,\n        'y_true'        : y_true,\n        'y_pred'        : y_pred,\n        'y_pred_probs'  : y_pred_probs\n    }\n\n\ndef plot_confusion_matrix(y_true, y_pred, title='Confusion Matrix', save_path=None):\n    \"\"\"\n    Plot a side-by-side raw-count + row-normalised confusion matrix.\n\n    Parameters\n    ----------\n    y_true     : array-like of int\n    y_pred     : array-like of int\n    title      : str\n    save_path  : str or None — if provided, figure is saved to disk\n    \"\"\"\n    cm      = confusion_matrix(y_true, y_pred)\n    cm_norm = cm.astype(float) / cm.sum(axis=1, keepdims=True)\n\n    fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n\n    sns.heatmap(\n        cm, annot=True, fmt='d', cmap='Blues',\n        xticklabels=CLASSES, yticklabels=CLASSES, ax=axes[0],\n        linewidths=0.5\n    )\n    axes[0].set_title(f'{title}\\n(Raw Counts)', fontsize=11)\n    axes[0].set_ylabel('True Label')\n    axes[0].set_xlabel('Predicted Label')\n\n    sns.heatmap(\n        cm_norm, annot=True, fmt='.3f', cmap='Blues',\n        xticklabels=CLASSES, yticklabels=CLASSES, ax=axes[1],\n        linewidths=0.5, vmin=0, vmax=1\n    )\n    axes[1].set_title(f'{title}\\n(Row-Normalised — Recall per Class)', fontsize=11)\n    axes[1].set_ylabel('True Label')\n    axes[1].set_xlabel('Predicted Label')\n\n    plt.tight_layout()\n    if save_path:\n        plt.savefig(save_path, dpi=150, bbox_inches='tight')\n        print(f\"  Confusion matrix saved: {save_path}\")\n    plt.show()\n\n\ndef plot_training_history(history, fold_id, phase='initial', save_path=None):\n    \"\"\"\n    Plot accuracy and loss curves for one (fold, phase) training run.\n\n    Parameters\n    ----------\n    history   : tf.keras.callbacks.History object\n    fold_id   : str or int\n    phase     : str\n    save_path : str or None\n    \"\"\"\n    fig, axes = plt.subplots(1, 2, figsize=(13, 4))\n\n    axes[0].plot(history.history['accuracy'],     label='Train Accuracy', lw=1.5)\n    axes[0].plot(history.history['val_accuracy'], label='Val Accuracy',   lw=1.5, ls='--')\n    axes[0].set_title(f'Fold {fold_id} — Accuracy [{phase}]', fontsize=11)\n    axes[0].set_xlabel('Epoch')\n    axes[0].set_ylabel('Accuracy')\n    axes[0].legend()\n    axes[0].grid(alpha=0.3)\n\n    axes[1].plot(history.history['loss'],     label='Train Loss', lw=1.5)\n    axes[1].plot(history.history['val_loss'], label='Val Loss',   lw=1.5, ls='--')\n    axes[1].set_title(f'Fold {fold_id} — Loss [{phase}]', fontsize=11)\n    axes[1].set_xlabel('Epoch')\n    axes[1].set_ylabel('Loss')\n    axes[1].legend()\n    axes[1].grid(alpha=0.3)\n\n    plt.tight_layout()\n    if save_path:\n        plt.savefig(save_path, dpi=150, bbox_inches='tight')\n        print(f\"  Training history saved: {save_path}\")\n    plt.show()\n\n\nprint(\"Evaluation utilities defined and ready.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-06T07:02:08.660521Z","iopub.execute_input":"2026-06-06T07:02:08.661166Z","iopub.status.idle":"2026-06-06T07:02:08.674216Z","shell.execute_reply.started":"2026-06-06T07:02:08.661137Z","shell.execute_reply":"2026-06-06T07:02:08.673641Z"}},"outputs":[{"name":"stdout","text":"Evaluation utilities defined and ready.\n","output_type":"stream"}],"execution_count":13},{"id":"8caf44c2","cell_type":"markdown","source":"## 7. Approach 1 — Fixed Train / Val / Test Split\n\nThis approach mirrors the training protocol of the base paper (Yinusa &\nFaezipour, 2025): a single, fixed train/validation partition is used.\nThe 80/20 split is stratified to ensure each class is represented\nproportionally in both train and validation sets.\n\n**Limitation acknowledged:** A single split produces a point estimate of\nvalidation accuracy with no variance information.  This is why Approaches\n2 and 3 add cross-validation.  Approach 1 is retained for direct\ncomparability with the base paper.","metadata":{}},{"id":"e08d1103","cell_type":"code","source":"print(\"=\" * 60)\nprint(\"  APPROACH 1: Fixed Train / Val / Test Split\")\nprint(\"=\" * 60)\n\n# Stratified 80 / 20 split of the training set\nA1_train_paths, A1_val_paths, A1_train_labels, A1_val_labels = train_test_split(\n    train_paths, train_labels,\n    test_size=VAL_SPLIT,\n    random_state=SEED,\n    stratify=train_labels\n)\n\nprint(f\"  Train : {len(A1_train_paths)} images\")\nprint(f\"  Val   : {len(A1_val_paths)} images\")\nprint(f\"  Test  : {len(test_paths)} images (LOCKED until Section 10)\")\n\nprint(\"\\n  Validation class distribution (should be uniform):\")\nfor i, cls in enumerate(CLASSES):\n    count = (A1_val_labels == i).sum()\n    print(f\"    {cls:15s}: {count}\")\n\n# Confirm balance\nval_class_counts = [(A1_val_labels == i).sum() for i in range(NUM_CLASSES)]\nassert max(val_class_counts) - min(val_class_counts) <= 2,     \"Validation split is not balanced — check stratify parameter.\"\nprint(\"\\n  Stratification verified.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-06T07:02:12.664575Z","iopub.execute_input":"2026-06-06T07:02:12.665244Z","iopub.status.idle":"2026-06-06T07:02:12.67772Z","shell.execute_reply.started":"2026-06-06T07:02:12.665215Z","shell.execute_reply":"2026-06-06T07:02:12.676716Z"}},"outputs":[{"name":"stdout","text":"============================================================\n  APPROACH 1: Fixed Train / Val / Test Split\n============================================================\n  Train : 4480 images\n  Val   : 1120 images\n  Test  : 1600 images (LOCKED until Section 10)\n\n  Validation class distribution (should be uniform):\n    glioma         : 280\n    meningioma     : 280\n    notumor        : 280\n    pituitary      : 280\n\n  Stratification verified.\n","output_type":"stream"}],"execution_count":14},{"id":"5c281f4a","cell_type":"code","source":"# ── Build tf.data datasets ────────────────────────────────────────────────\nA1_train_ds = make_dataset(A1_train_paths, A1_train_labels, augment=True,  shuffle_data=True)\nA1_val_ds   = make_dataset(A1_val_paths,   A1_val_labels,   augment=False, shuffle_data=False)\n\n# ── Phase 1: Train with frozen VGG16 backbone ─────────────────────────────\nprint(\"\\n--- Phase 1: Frozen VGG16 backbone (head-only training) ---\")\nA1_model = build_vgg16_model(learning_rate=LR_INITIAL, trainable_base=False)\nA1_cbs_p1, A1_ckpt_p1 = get_callbacks(fold_id='A1', phase='initial')\n\nA1_hist_p1 = A1_model.fit(\n    A1_train_ds,\n    validation_data=A1_val_ds,\n    epochs=EPOCHS,\n    callbacks=A1_cbs_p1,\n    verbose=1\n)\n\nplot_training_history(\n    A1_hist_p1, fold_id='A1', phase='initial',\n    save_path=f'{LOG_DIR}/A1_phase1_history.png'\n)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-06T07:02:17.018941Z","iopub.execute_input":"2026-06-06T07:02:17.019475Z","iopub.status.idle":"2026-06-06T07:07:54.324113Z","shell.execute_reply.started":"2026-06-06T07:02:17.019444Z","shell.execute_reply":"2026-06-06T07:07:54.323385Z"}},"outputs":[{"name":"stdout","text":"\n--- Phase 1: Frozen VGG16 backbone (head-only training) ---\nEpoch 1/30\n","output_type":"stream"},{"name":"stderr","text":"WARNING: All log messages before absl::InitializeLog() is called are written to STDERR\nI0000 00:00:1780729338.751961     138 service.cc:152] XLA service 0x7b75d0005f10 initialized for platform CUDA (this does not guarantee that XLA will be used). Devices:\nI0000 00:00:1780729338.752028     138 service.cc:160]   StreamExecutor device (0): Tesla T4, Compute Capability 7.5\nI0000 00:00:1780729338.752036     138 service.cc:160]   StreamExecutor device (1): Tesla T4, Compute Capability 7.5\nI0000 00:00:1780729339.235670     138 cuda_dnn.cc:529] Loaded cuDNN version 91002\n","output_type":"stream"},{"name":"stdout","text":"\u001b[1m  3/140\u001b[0m \u001b[37m━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[1m7s\u001b[0m 57ms/step - accuracy: 0.2135 - loss: 1.9901","output_type":"stream"},{"name":"stderr","text":"I0000 00:0